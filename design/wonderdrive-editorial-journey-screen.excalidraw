      "fontSize": 34,
      "fontFamily": 2,
      "text": "Why do cities preserve some memories—and erase others?",
      "textAlign": "left",
      "verticalAlign": "top",
      "containerId": null,
      "originalText": "Why do cities preserve some memories—and erase others?",
      "autoResize": true,
      "lineHeight": 1.25
    },
    {
      "id": "wd-editorial-25",
      "type": "text",
      "x": 102,
      "y": 261,
      "width": 1260,
      "height": 17.5,
      "angle": 0,
      "strokeColor": "#69747d",
      "backgroundColor": "transparent",
      "fillStyle": "solid",
      "strokeWidth": 1,
      "strokeStyle": "solid",
      "roughness": 0,
      "opacity": 100,
      "groupIds": [],
      "frameId": null,
      "index": "ap",
      "roundness": null,
      "seed": 26425,
      "version": 1,
      "versionNonce": 55275,
      "isDeleted": false,
      "boundElements": null,
      "updated": 1784073600000,
      "link": null,
      "locked": false,
      "fontSize": 14,
      "fontFamily": 2,
      "text": "A city remembers through more than archives. Its streets, monuments, rituals, and absences all tell us who had the power to make a past feel permanent.",
      "textAlign": "left",
      "verticalAlign": "top",
      "containerId": null,
      "originalText": "A city remembers through more than archives. Its streets, monuments, rituals, and absences all tell us who had the power to make a past feel permanent.",
      "autoResize": true,
      "lineHeight": 1.25
    },
