    {
      "id": "wd-editorial-34",
      "type": "text",
      "x": 146,
      "y": 548,
      "width": 770,
      "height": 35.1,
      "angle": 0,
      "strokeColor": "#17212b",
      "backgroundColor": "transparent",
      "fillStyle": "solid",
      "strokeWidth": 1,
      "strokeStyle": "solid",
      "roughness": 0,
      "opacity": 100,
      "groupIds": [],
      "frameId": null,
      "index": "ay",
      "roundness": null,
      "seed": 27298,
      "version": 1,
      "versionNonce": 56454,
      "isDeleted": false,
      "boundElements": null,
      "updated": 1784073600000,
      "link": null,
      "locked": false,
      "fontSize": 13,
      "fontFamily": 2,
      "text": "Demolition, redevelopment, and removed records can make a community's history harder to see.\nUnofficial memory persists through oral history, family archives, protest, and familiar names. [3][4]",
      "textAlign": "left",
      "verticalAlign": "top",
      "containerId": null,
      "originalText": "Demolition, redevelopment, and removed records can make a community's history harder to see.\nUnofficial memory persists through oral history, family archives, protest, and familiar names. [3][4]",
      "autoResize": true,
      "lineHeight": 1.35
    },
