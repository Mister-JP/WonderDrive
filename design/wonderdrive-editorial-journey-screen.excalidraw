      "locked": false,
      "fontSize": 20,
      "fontFamily": 2,
      "text": "Memory becomes infrastructure",
      "textAlign": "left",
      "verticalAlign": "top",
      "containerId": null,
      "originalText": "Memory becomes infrastructure",
      "autoResize": true,
      "lineHeight": 1.25
    },
    {
      "id": "wd-editorial-29",
      "type": "text",
      "x": 146,
      "y": 361,
      "width": 770,
      "height": 35.1,
      "angle": 0,
      "strokeColor": "#17212b",
      "backgroundColor": "transparent",
      "fillStyle": "solid",
      "strokeWidth": 1,
      "strokeStyle": "solid",
      "roughness": 0,
      "opacity": 100,
      "groupIds": [],
      "frameId": null,
      "index": "at",
      "roundness": null,
      "seed": 26813,
      "version": 1,
      "versionNonce": 55799,
      "isDeleted": false,
      "boundElements": null,
      "updated": 1784073600000,
      "link": null,
      "locked": false,
      "fontSize": 13,
      "fontFamily": 2,
      "text": "Street names, preserved buildings, and public ceremonies make selected stories part of daily life.\nThey turn memory into something people repeatedly encounter—not simply something stored away. [1]",
      "textAlign": "left",
      "verticalAlign": "top",
      "containerId": null,
      "originalText": "Street names, preserved buildings, and public ceremonies make selected stories part of daily life.\nThey turn memory into something people repeatedly encounter—not simply something stored away. [1]",
      "autoResize": true,
      "lineHeight": 1.35
    },
    {
      "id": "wd-editorial-30",
      "type": "text",
      "x": 146,
      "y": 428,
      "width": 770,
      "height": 35.1,
      "angle": 0,
      "strokeColor": "#17212b",
      "backgroundColor": "transparent",
      "fillStyle": "solid",
      "strokeWidth": 1,
      "strokeStyle": "solid",
      "roughness": 0,
      "opacity": 100,
      "groupIds": [],
      "frameId": null,
      "index": "au",
      "roundness": null,
      "seed": 26910,
      "version": 1,
      "versionNonce": 55930,
      "isDeleted": false,
      "boundElements": null,
      "updated": 1784073600000,
      "link": null,
      "locked": false,
      "fontSize": 13,
      "fontFamily": 2,
      "text": "That visibility gives official memory unusual staying power. A map can quietly teach a hierarchy:\nwhich places are centered, which are renamed, and which disappear at the edge. [2]",
      "textAlign": "left",
      "verticalAlign": "top",
      "containerId": null,
      "originalText": "That visibility gives official memory unusual staying power. A map can quietly teach a hierarchy:\nwhich places are centered, which are renamed, and which disappear at the edge. [2]",
      "autoResize": true,
      "lineHeight": 1.35
    },
